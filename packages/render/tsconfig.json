{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src",
    "types": ["vitest/globals", "node"],
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*", "stories/**/*", ".storybook/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist", "storybook-static"]
}
