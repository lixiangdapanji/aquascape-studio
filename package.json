{
  "name": "aquascape-studio",
  "version": "0.0.0",
  "private": true,
  "description": "Glue repo for aquascape-studio — submodule pins, integration tests, E2E, and docs. Application code lives in the aquascape-* leaf repos.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "submodules:init": "git submodule update --init --recursive",
    "submodules:update": "git submodule update --remote --merge",
    "e2e": "playwright test --config=e2e/playwright.config.ts",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "typescript": "^5.6.0"
  }
}
